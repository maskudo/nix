#!/usr/bin/env bash

# bitwarden exported vault file without encryption
VAULT="$HOME/.passwords.json"

jq -r '.items[] | "\(.id)\t\(.name)"' "$VAULT" |
  fzf \
    --with-nth=2 \
    --border \
    --preview "jq -r --arg id {1} '.items[] | select(.id==\$id) | \"username: \(.login.username)\nurl: \(.login.uris[].uri)\n\"' $VAULT " \
    --bind "ctrl-u:execute-silent( jq -r --arg id {1} '.items[] | select(.id==\$id) | .login.username' $VAULT | wl-copy )+abort" \
    --bind "ctrl-y:execute-silent( jq -r --arg id {1} '.items[] | select(.id==\$id) | .login.password' $VAULT | wl-copy )+abort" \
    --bind "enter:execute-silent( jq -r --arg id {1} '.items[] | select(.id==\$id) | .login.password' $VAULT | wl-copy )+abort"
