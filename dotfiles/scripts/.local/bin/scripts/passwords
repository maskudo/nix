#!/usr/bin/env bash

VAULT="$HOME/.passwords.json"

# clipboard backend
if command -v pbcopy >/dev/null 2>&1; then
  CLIP_CMD="pbcopy"
elif [ -n "$WAYLAND_DISPLAY" ] && command -v wl-copy >/dev/null 2>&1; then
  CLIP_CMD="wl-copy"
elif [ -n "$DISPLAY" ] && command -v xclip >/dev/null 2>&1; then
  CLIP_CMD="xclip -selection clipboard"
else
  echo "No clipboard utility found."
  exit 1
fi

jq -r '.items[] | "\(.id)\t\(.name)"' "$VAULT" |
  fzf \
    --with-nth=2 \
    --border \
    --preview "jq -r --arg id {1} '.items[] | select(.id==\$id) | \"username: \(.login.username)\nurl: \(.login.uris[].uri)\n\"' $VAULT" \
    --header 'C-u: Username | C-y: Password | Enter: Password' \
    --bind "ctrl-u:execute-silent(
        jq -r --arg id {1} '.items[] | select(.id==\$id) | .login.username' $VAULT | $CLIP_CMD
    )+abort" \
    --bind "ctrl-y:execute-silent(
        jq -r --arg id {1} '.items[] | select(.id==\$id) | .login.password' $VAULT | $CLIP_CMD
    )+abort" \
    --bind "enter:execute-silent(
        jq -r --arg id {1} '.items[] | select(.id==\$id) | .login.password' $VAULT | $CLIP_CMD
    )+abort"
